# Database
POSTGRES_USER=recruitment_user
POSTGRES_PASSWORD=recruitment_password_dev
POSTGRES_DB=recruitment_db
DATABASE_URL=postgresql://recruitment_user:recruitment_password_dev@postgres:5432/recruitment_db

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin_password_dev@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin_password_dev

# Backend
SECRET_KEY=your-secret-key-change-in-production-123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
DEBUG=true
SQLALCHEMY_ECHO=false

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development
CHOKIDAR_USEPOLLING=true